# Virtual environments
venv/
.venv/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Environment variables
.env
.env.*

# Jupyter
.ipynb_checkpoints/

# Dataset caches (Hugging Face, Kaggle)
dataset/
hf_cache/
.cache/
.kaggle/

# Audio files (provided via Kaggle, never committed)
data/*/audio/*
!data/*/audio/.gitkeep

# Model artifacts (local only)
models/*
!models/.gitkeep
!models/gmm_models/
!models/gmm_models/.gitkeep

# Results contents (keep directory structure)
results/metrics/*
!results/metrics/.gitkeep
results/plots/*
!results/plots/.gitkeep
results/embeddings/*
!results/embeddings/.gitkeep
results/confusion_matrix/*
!results/confusion_matrix/.gitkeep

# Binary / large files
*.wav
*.mp3
*.flac
*.npy
*.npz
*.pkl
*.joblib
*.pt
*.pth
*.h5
*.ckpt
*.zip
*.tar
*.tar.gz
*.7z
*.rar

# Logs
*.log

# Credentials
kaggle.json

# OS artifacts
.DS_Store
Thumbs.db
